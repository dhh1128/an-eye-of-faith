---
layout: null
permalink: /search.json
---
{%- comment -%}
  Full-text search index for the homepage live search (Lunr.js).
  Generated by Jekyll from the same page set the site publishes, so it stays
  complete by construction. Excludes the homepage itself (url == "/").
{%- endcomment -%}
{%- assign indexed = site.html_pages | where_exp: "p", "p.title" | where_exp: "p", "p.url != '/'" -%}
[
{%- for p in indexed -%}
  {
    "title": {{ p.title | jsonify }},
    "url": {{ p.url | relative_url | jsonify }},
    "date": {{ p.date | date: "%Y-%m-%d" | jsonify }},
    "content": {{ p.content | strip_html | strip_newlines | jsonify }}
  }{%- unless forloop.last -%},{%- endunless -%}
{%- endfor -%}
]
